; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Densetsu"
run/main_scene="res://engine3d/loading/DensetsuBootLoader.tscn"
config/features=PackedStringArray("4.6")
config/icon="uid://bxg8j1vg0540x"

[display]

window/size/mode=2
window/size/initial_position_type=3
window/size/initial_screen=1
window/size/extend_to_title=true
window/per_pixel_transparency/allowed=true

[editor_plugins]

enabled=PackedStringArray("res://addons/densetsu_autocliff/plugin.cfg", "res://addons/densetsu_geometry_obj_export/plugin.cfg", "res://addons/densetsu_tool_suite/plugin.cfg", "res://addons/goshapes/plugin.cfg", "res://addons/nexus_vertex_painter/plugin.cfg", "res://addons/terrain_3d/plugin.cfg", "res://addons/transform_variance/plugin.cfg")

